# HTS terminology server — copy to deploy/env/hts.env
#
# Import terminology from atrius-hfs before production use:
#   see atrius-hfs/docs/clinical-reasoning/data-import.md

HTS_SERVER_HOST=127.0.0.1
HTS_SERVER_PORT=9091
HTS_LOG_LEVEL=info

HTS_STORAGE_BACKEND=sqlite
HTS_DATABASE_URL=./data/hts.db

HTS_ENABLE_CORS=true
HTS_CORS_ORIGINS=*

# Optional: auto-import on startup when directory contains terminology packages
# HTS_BOOTSTRAP_DIR=${ATRIUS_HFS_PATH}/crates/hts/terminology-data
