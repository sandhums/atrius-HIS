# his-server — copy to deploy/env/his-server.env

HIS_SERVER_HOST=127.0.0.1
HIS_SERVER_PORT=8096

HIS_FHIR_BASE_URL=http://127.0.0.1:8082
HIS_TERMINOLOGY_URL=http://127.0.0.1:9091
HIS_DEFAULT_TENANT=atrius-hospital

# Inbound JWT validation (helios-auth). When enabled, BFF must forward user bearer tokens.
# Falls back to HFS_AUTH_* env vars if HIS_AUTH_* unset.
# HIS_AUTH_ENABLED=true
# HIS_AUTH_JWKS_URL=https://localhost:8443/realms/fhir/protocol/openid-connect/certs
# HIS_AUTH_ISSUER=https://localhost:8443/realms/fhir
# HIS_AUTH_TENANT_CLAIM=organization_id
# HIS_AUTH_INSECURE_TLS=true
# HIS_AUTH_JTI_REVOCATION=true
# HIS_AUTH_REDIS_URL=redis://127.0.0.1:6379

# Offline jobs / smoke scripts only (not for interactive UI via BFF):
# export HIS_FHIR_BEARER_TOKEN=$(./deploy/keycloak/get-token.sh his-backend-client)

RUST_LOG=info,his_server=debug,his_domain=debug
