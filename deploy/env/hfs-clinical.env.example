# Clinical HFS — local dev (Postgres fhir_server + local Keycloak :8443)
# Copy to deploy/env/hfs-clinical.env and adjust paths.
#
# Requires:
#   - Local Postgres :5432 / fhir_server (or set HFS_DATABASE_URL)
#   - Local Keycloak https://localhost:8443 / keycloak_db
#   - HFS built from sibling atrius-hfs repo
#   - Profile manifest from atrius-hfs/manifests/
#
# Elasticsearch is optional — use HFS_STORAGE_BACKEND=postgres (no ES) or
# postgres-elasticsearch + docker compose elasticsearch on :9200.

HFS_SERVER_HOST=127.0.0.1
HFS_SERVER_PORT=8082
HFS_BASE_URL=http://127.0.0.1:8082
HFS_DEFAULT_FHIR_VERSION=R4
HFS_DATA_DIR=${ATRIUS_HFS_PATH}/data

# Persistence — postgres-only (no Elasticsearch required)
HFS_STORAGE_BACKEND=postgres
HFS_DATABASE_URL=postgresql://sandhu:parsons02@127.0.0.1:5432/fhir_server
HFS_COMPOSITE_SYNC_MODE=synchronous

# If using postgres-elasticsearch instead:
# HFS_STORAGE_BACKEND=postgres-elasticsearch
# HFS_ELASTICSEARCH_NODES=http://127.0.0.1:9200
# HFS_ELASTICSEARCH_INDEX_PREFIX=hfs-clinical

# Atrius profile validation
HFS_PROFILE_MANIFEST=${ATRIUS_HFS_PATH}/manifests/atrius-r4-profile-manifest-core.json
HFS_PROFILE_VALIDATION_MODE=strict
HFS_PROFILE_VALIDATION_ADDONS=false

# Terminology (HTS)
HFS_TERMINOLOGY_SERVER=http://127.0.0.1:9091

# Multi-tenancy — one tenant per hospital in pilot
HFS_DEFAULT_TENANT=atrius-hospital
HFS_TENANT_ROUTING_MODE=header_only

# SMART auth — local Keycloak
HFS_AUTH_ENABLED=true
HFS_AUTH_JWKS_URL=https://localhost:8443/realms/fhir/protocol/openid-connect/certs
HFS_AUTH_ISSUER=https://localhost:8443/realms/fhir
HFS_AUTH_TENANT_CLAIM=organization_id
# reqwest/rustls uses Mozilla roots, not macOS Keychain — set true for local self-signed Keycloak:
HFS_AUTH_INSECURE_TLS=true
# Logout blocklist — same Redis as BFF (helios-auth redis is always linked in HFS builds):
# HFS_AUTH_JTI_REVOCATION=true
# HFS_AUTH_REDIS_URL=redis://127.0.0.1:6379
# Keycloak client-credentials tokens often use aud=account; omit to skip aud check in dev:
# HFS_AUTH_AUDIENCE=account

HFS_SMART_TOKEN_ENDPOINT=https://localhost:8443/realms/fhir/protocol/openid-connect/token
HFS_SMART_AUTHORIZE_ENDPOINT=https://localhost:8443/realms/fhir/protocol/openid-connect/auth
HFS_SMART_JWKS_URL=https://localhost:8443/realms/fhir/protocol/openid-connect/certs

# Audit (file sink for local dev)
HFS_AUDIT_BACKEND=file
HFS_AUDIT_FILE_PATH=./data/audit-clinical.ndjson

# Subscriptions (enable when testing ADT/scheduling events)
# Build HFS with: cargo build -p helios-hfs --features subscriptions
# HFS_SUBSCRIPTIONS_ENABLED=true

HFS_LOG_LEVEL=info
